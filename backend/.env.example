# Copy this file to backend/.env, then replace the placeholder values.
# Do not commit backend/.env to GitHub.

# Optional local Docker MySQL settings.
MYSQL_ROOT_PASSWORD=root-password
MYSQL_DATABASE=whu_circle
MYSQL_USER=whu_circle
MYSQL_PASSWORD=dev-password

# Shared team database over Tailscale.
# If you want to use your own local MySQL, change host, username and password.
DB_URL=jdbc:mysql://100.97.230.36:3306/whu_circle?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
DB_USERNAME=whu_team
DB_PASSWORD=replace-with-shared-db-password

# QQ SMTP settings for real email verification codes.
# MAIL_AUTH_CODE is the QQ Mail SMTP authorization code, not the QQ login password.
MAIL_USERNAME=your-account@qq.com
MAIL_AUTH_CODE=replace-with-qq-mail-authorization-code
MAIL_FROM=your-account@qq.com
